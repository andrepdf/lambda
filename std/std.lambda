id    := \ x . x
Y     := \ f . (\ x . f (x x)) (\ x . f (x x))

// Booleans
if    := id
true  := \ a b . a
false := \ a b . b
not   := \ p   . p false true
and   := \ p q . p q p
or    := \ p q . p p q
xor   := \ p q . p (not q) q
nand  := \ p q . not (and p q)

// Pairs
pair  := \ x y z . z x y
fst   := \ p     . p true
snd   := \ p     . p false

// Numerals
zero  := \ f x     . x
succ  := \ n f x   . f (n f x)
plus  := \ m n f x . m f (n f x)
mult  := \ m n f x . m (n f) x
